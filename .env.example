# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# You can get this key from https://openrouter.ai/keys
# Paste your OpenRouter API Key here:
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY_HERE"

# OPENROUTER_MODEL: The specific model you want to use via OpenRouter.
# Examples: google/gemini-2.5-flash, anthropic/claude-3.5-sonnet, etc.
OPENROUTER_MODEL="google/gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# --- SUI NETWORK & CONTRACT CONFIGURATION ---
# The target Sui network (testnet for development)
VITE_SUI_NETWORK="testnet"
VITE_SUI_GRAPHQL_URL="https://graphql.testnet.sui.io/graphql"

# The Move Package ID of your deployed AgentPolicy contract on TESTNET
VITE_AGENT_POLICY_PACKAGE_ID=""

# The Deepbook v3 Package ID on Testnet
VITE_DEEPBOOK_PACKAGE_ID="0xfb28c4cbc6865bd1c897d26aecbe1f8792d1509a20ffec692c800660cbec6982"

