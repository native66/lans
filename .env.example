# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# You can get this key from https://openrouter.ai/keys
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL: The specific model you want to use via OpenRouter.
# Examples: google/gemini-2.5-flash, anthropic/claude-3.5-sonnet, etc.
OPENROUTER_MODEL="google/gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- SUI NETWORK & CONTRACT CONFIGURATION ---
# The target Sui network (mainnet, testnet, devnet)
VITE_SUI_NETWORK="mainnet"
VITE_SUI_GRAPHQL_URL="https://sui-mainnet.mystenlabs.com/graphql"

# The Move Package ID of your deployed AgentPolicy contract
VITE_AGENT_POLICY_PACKAGE_ID="0xYOUR_PACKAGE_ID"

# The Deepbook v3 Package ID (0xdee9 on Mainnet)
VITE_DEEPBOOK_PACKAGE_ID="0xdee9"

# Note: The AI Agent's Wallet is NOT configured via ENV by the user. 
# The backend dynamically generates an ephemeral Keypair for each Agent Strategy 
# and the Owner authorizes its public key via the Move Policy Object.
